# Set default recipe
default: list

# List all available recipes
list:
    @just --list

# Run the full pipeline
run:
    uv run python -m infrastructure.orchestration.run

# Run specific stage
run-stage stage:
    uv run python -m application.stage.{{stage}}

# Run all quality checks
check:
    uvx prek run --all-files

# Run unit tests
test-unit:
    uv run pytest tests/unit/

# Run integration tests
test-integration:
    uv run pytest tests/integration/

# Clean up data and caches
clean:
    rm -rf data/*
    uvx pyclean . -d all
